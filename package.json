{
  "name": "trimurl",
  "version": "1.0.0",
  "description": "Url-shortener project",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate --config prisma.config.ts && tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "postinstall": "prisma generate --config prisma.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ellaomoni/TrimURL.git"
  },
  "keywords": [],
